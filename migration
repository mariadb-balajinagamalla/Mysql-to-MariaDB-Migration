#!/usr/bin/env bash
set -euo pipefail

run_signature() {
  printf "%s\n" \
    "MODE=$MODE" \
    "SRC_HOST=$SRC_HOST" \
    "SRC_PORT=$SRC_PORT" \
    "SRC_ADMIN_USER=$SRC_ADMIN_USER" \
    "SRC_DBS_INPUT=$SRC_DBS_INPUT" \
    "TGT_HOST=$TGT_HOST" \
    "TGT_PORT=$TGT_PORT" \
    "TGT_ADMIN_USER=$TGT_ADMIN_USER" \
    "TGT_SSH_HOST=$TGT_SSH_HOST" \
    "TGT_SSH_USER=$TGT_SSH_USER" \
    "MIGRATE_APP_USERS=$MIGRATE_APP_USERS" \
    "REPL_USER=$REPL_USER" \
    "INPLACE_BACKUP_DIR=$INPLACE_BACKUP_DIR" \
    "INPLACE_EXECUTE=$INPLACE_EXECUTE" \
    "REPLACE_TARGET_OS=$REPLACE_TARGET_OS" \
    "REPLACE_MARIADB_VERSION=$REPLACE_MARIADB_VERSION" \
    "REPLACE_DELETE_OLD_MYSQL_DATA=$REPLACE_DELETE_OLD_MYSQL_DATA"
}

prompt() {
  local label="$1"
  local def="${2:-}"
  local var
  if [[ -n "$def" ]]; then
    read -r -p "$label [$def]: " var
    printf "%s" "${var:-$def}"
  else
    read -r -p "$label: " var
    printf "%s" "$var"
  fi
}

prompt_secret() {
  local label="$1"
  local var
  read -r -s -p "$label: " var
  printf "\n"
  printf "%s" "$var"
}

source_version_check_inplace() {
  local mysql_bin="${MYSQL_BIN:-mysql}"
  if ! command -v "$mysql_bin" >/dev/null 2>&1; then
    echo "ERROR: mysql client not found for inplace version check (MYSQL_BIN=$mysql_bin)."
    exit 1
  fi
  local src_version
  src_version="$(MYSQL_PWD="$SRC_ADMIN_PASS" "$mysql_bin" --protocol=TCP -h"$SRC_HOST" -P"$SRC_PORT" -u"$SRC_ADMIN_USER" \
    --batch --skip-column-names -e "SELECT VERSION();" 2>/dev/null | head -n1)"
  if [[ -z "$src_version" ]]; then
    echo "ERROR: Could not detect source version for inplace mode."
    exit 1
  fi
  local mm
  mm="$(printf "%s" "$src_version" | sed -E 's/^([0-9]+)\.([0-9]+).*/\1.\2/')"
  local major minor
  major="$(printf "%s" "$mm" | cut -d. -f1)"
  minor="$(printf "%s" "$mm" | cut -d. -f2)"
  if [[ "$major" -gt 8 || ( "$major" -eq 8 && "$minor" -ge 0 ) ]]; then
    echo "ERROR: In-place mode is not supported for MySQL 8.0+ in this tool."
    echo "Detected source version: $src_version"
    echo "Use one_step, two_step, or binlog mode."
    exit 1
  fi
}

CFG_REPL_USER=""
CFG_REPL_PASS=""
CFG_INPLACE_BACKUP_DIR=""
CFG_INPLACE_EXECUTE=""
CFG_INPLACE_STOP_CMD=""
CFG_INPLACE_INSTALL_CMD=""
CFG_INPLACE_START_CMD=""
CFG_INPLACE_UPGRADE_CMD=""
CFG_REPLACE_BACKUP_CMD=""
CFG_REPLACE_STOP_MYSQL_CMD=""
CFG_REPLACE_UNINSTALL_MYSQL_CMD=""
CFG_REPLACE_TARGET_OS=""
CFG_REPLACE_MARIADB_VERSION=""
CFG_REPLACE_START_MARIADB_CMD=""
CFG_REPLACE_DELETE_OLD_MYSQL_DATA=""
CFG_REPLACE_CLEANUP_CMD=""

if [[ -f "config/migration.yaml" ]]; then
  while IFS=$'\t' read -r cfg_key cfg_val; do
    case "$cfg_key" in
      REPL_USER) CFG_REPL_USER="$cfg_val" ;;
      REPL_PASS) CFG_REPL_PASS="$cfg_val" ;;
      INPLACE_BACKUP_DIR) CFG_INPLACE_BACKUP_DIR="$cfg_val" ;;
      INPLACE_EXECUTE) CFG_INPLACE_EXECUTE="$cfg_val" ;;
      INPLACE_STOP_CMD) CFG_INPLACE_STOP_CMD="$cfg_val" ;;
      INPLACE_INSTALL_CMD) CFG_INPLACE_INSTALL_CMD="$cfg_val" ;;
      INPLACE_START_CMD) CFG_INPLACE_START_CMD="$cfg_val" ;;
      INPLACE_UPGRADE_CMD) CFG_INPLACE_UPGRADE_CMD="$cfg_val" ;;
      REPLACE_BACKUP_CMD) CFG_REPLACE_BACKUP_CMD="$cfg_val" ;;
      REPLACE_STOP_MYSQL_CMD) CFG_REPLACE_STOP_MYSQL_CMD="$cfg_val" ;;
      REPLACE_UNINSTALL_MYSQL_CMD) CFG_REPLACE_UNINSTALL_MYSQL_CMD="$cfg_val" ;;
      REPLACE_TARGET_OS) CFG_REPLACE_TARGET_OS="$cfg_val" ;;
      REPLACE_MARIADB_VERSION) CFG_REPLACE_MARIADB_VERSION="$cfg_val" ;;
      REPLACE_START_MARIADB_CMD) CFG_REPLACE_START_MARIADB_CMD="$cfg_val" ;;
      REPLACE_DELETE_OLD_MYSQL_DATA) CFG_REPLACE_DELETE_OLD_MYSQL_DATA="$cfg_val" ;;
      REPLACE_CLEANUP_CMD) CFG_REPLACE_CLEANUP_CMD="$cfg_val" ;;
    esac
  done < <(
    awk '
      $0 ~ /^env:[[:space:]]*$/ { in_env=1; next }
      in_env && $0 ~ /^[^ ]/ { in_env=0 }
      in_env && $0 ~ /^  [A-Za-z0-9_]+:/ {
        key=$1
        sub(":", "", key)
        $1=""
        sub(/^[[:space:]]+/, "", $0)
        sub(/[[:space:]]*#.*/, "", $0)
        gsub(/^"/, "", $0)
        gsub(/"$/, "", $0)
        sub(/^[[:space:]]+/, "", $0)
        sub(/[[:space:]]+$/, "", $0)
        print key "\t" $0
      }
    ' config/migration.yaml
  )
fi

echo "==> MySQL to MariaDB Migration"
MODE="$(prompt "Mode (one_step|two_step|binlog|inplace|replace_slave)" "one_step")"
MODE="${MODE// /}"
if [[ "$MODE" != "one_step" && "$MODE" != "two_step" && "$MODE" != "binlog" && "$MODE" != "inplace" && "$MODE" != "replace_slave" ]]; then
  echo "ERROR: mode must be one_step, two_step, binlog, inplace or replace_slave"
  exit 1
fi

SRC_HOST="$(prompt "Source host" "")"
SRC_PORT="$(prompt "Source port" "3306")"
SRC_ADMIN_USER="$(prompt "Source admin user" "")"
SRC_ADMIN_PASS="$(prompt_secret "Source admin password")"
SRC_ADMIN_PASS="${SRC_ADMIN_PASS#"${SRC_ADMIN_PASS%%[![:space:]]*}"}"
SRC_ADMIN_PASS="${SRC_ADMIN_PASS%"${SRC_ADMIN_PASS##*[![:space:]]}"}"
if [[ "$MODE" == "inplace" ]]; then
  source_version_check_inplace
fi
SRC_USER="$SRC_ADMIN_USER"
SRC_PASS="$SRC_ADMIN_PASS"
SRC_DBS_INPUT=""
if [[ "$MODE" != "inplace" ]]; then
  SRC_DBS_INPUT="$(prompt "Database name(s) (comma-separated)" "")"
fi

TGT_HOST=""
TGT_PORT="3306"
TGT_ADMIN_USER=""
TGT_ADMIN_PASS=""
TGT_SSH_HOST=""
TGT_SSH_USER="root"
TGT_SSH_OPTS="-o StrictHostKeyChecking=no"
if [[ "$MODE" != "inplace" ]]; then
  TGT_HOST="$(prompt "Target host" "")"
  TGT_PORT="$(prompt "Target port" "3306")"
  TGT_ADMIN_USER="$(prompt "Target admin user" "")"
  TGT_ADMIN_PASS="$(prompt_secret "Target admin password")"
  TGT_ADMIN_PASS="${TGT_ADMIN_PASS#"${TGT_ADMIN_PASS%%[![:space:]]*}"}"
  TGT_ADMIN_PASS="${TGT_ADMIN_PASS%"${TGT_ADMIN_PASS##*[![:space:]]}"}"
  TGT_SSH_HOST="$(prompt "Target SSH host (leave blank if not using SSH)" "")"
  TGT_SSH_USER="$(prompt "Target SSH user" "root")"
  TGT_SSH_OPTS="$(prompt "Target SSH options" "-o StrictHostKeyChecking=no")"
fi

TGT_USER="$TGT_ADMIN_USER"
TGT_PASS="$TGT_ADMIN_PASS"

MIGRATE_APP_USERS="0"
APP_USER_DEFAULT_PASSWORD=""
if [[ "$MODE" != "inplace" ]]; then
  MIGRATE_APP_USERS="$(prompt "Migrate application users? (y/n)" "y")"
  if [[ "$(printf "%s" "$MIGRATE_APP_USERS" | tr '[:upper:]' '[:lower:]')" == "y" ]]; then
    MIGRATE_APP_USERS="1"
    APP_USER_DEFAULT_PASSWORD="$(prompt_secret "Default password for app users")"
  else
    MIGRATE_APP_USERS="0"
    APP_USER_DEFAULT_PASSWORD=""
  fi
fi

INPLACE_BACKUP_DIR="$CFG_INPLACE_BACKUP_DIR"
INPLACE_EXECUTE="$CFG_INPLACE_EXECUTE"
INPLACE_STOP_CMD="$CFG_INPLACE_STOP_CMD"
INPLACE_INSTALL_CMD="$CFG_INPLACE_INSTALL_CMD"
INPLACE_START_CMD="$CFG_INPLACE_START_CMD"
INPLACE_UPGRADE_CMD="$CFG_INPLACE_UPGRADE_CMD"
if [[ "$MODE" == "inplace" ]]; then
  if [[ -z "$INPLACE_BACKUP_DIR" ]]; then INPLACE_BACKUP_DIR="artifacts/inplace_backup"; fi
  INPLACE_BACKUP_DIR="$(prompt "In-place backup directory" "$INPLACE_BACKUP_DIR")"
  inplace_execute_answer="$(prompt "Execute in-place commands now? (y/n)" "n")"
  if [[ "$(printf "%s" "$inplace_execute_answer" | tr '[:upper:]' '[:lower:]')" == "y" ]]; then
    INPLACE_EXECUTE="1"
  else
    INPLACE_EXECUTE="0"
  fi
  if [[ -z "$INPLACE_STOP_CMD" ]]; then INPLACE_STOP_CMD="sudo systemctl stop mysql || sudo systemctl stop mysqld"; fi
  if [[ -z "$INPLACE_START_CMD" ]]; then INPLACE_START_CMD="sudo systemctl start mariadb || sudo systemctl start mysql"; fi
  if [[ -z "$INPLACE_UPGRADE_CMD" ]]; then INPLACE_UPGRADE_CMD="mariadb-upgrade"; fi
  INPLACE_STOP_CMD="$(prompt "In-place stop command" "$INPLACE_STOP_CMD")"
  INPLACE_INSTALL_CMD="$(prompt "In-place install command (required if execute=y)" "$INPLACE_INSTALL_CMD")"
  INPLACE_START_CMD="$(prompt "In-place start command" "$INPLACE_START_CMD")"
  INPLACE_UPGRADE_CMD="$(prompt "In-place upgrade command" "$INPLACE_UPGRADE_CMD")"
  if [[ "$INPLACE_EXECUTE" == "1" && -z "$INPLACE_INSTALL_CMD" ]]; then
    echo "ERROR: In-place install command is required when execute=y."
    exit 1
  fi
else
  if [[ -z "$INPLACE_BACKUP_DIR" ]]; then INPLACE_BACKUP_DIR=""; fi
  if [[ -z "$INPLACE_EXECUTE" ]]; then INPLACE_EXECUTE="0"; fi
fi

REPL_USER="$CFG_REPL_USER"
REPL_PASS="$CFG_REPL_PASS"
if [[ "$MODE" == "binlog" || "$MODE" == "replace_slave" ]]; then
  REPL_USER="$(prompt "Replication user" "${REPL_USER:-repl}")"
  REPL_PASS="$(prompt_secret "Replication password")"
  REPL_PASS="${REPL_PASS#"${REPL_PASS%%[![:space:]]*}"}"
  REPL_PASS="${REPL_PASS%"${REPL_PASS##*[![:space:]]}"}"
fi

REPLACE_BACKUP_CMD="$CFG_REPLACE_BACKUP_CMD"
REPLACE_STOP_MYSQL_CMD="$CFG_REPLACE_STOP_MYSQL_CMD"
REPLACE_UNINSTALL_MYSQL_CMD="$CFG_REPLACE_UNINSTALL_MYSQL_CMD"
REPLACE_TARGET_OS="$CFG_REPLACE_TARGET_OS"
REPLACE_MARIADB_VERSION="$CFG_REPLACE_MARIADB_VERSION"
REPLACE_START_MARIADB_CMD="$CFG_REPLACE_START_MARIADB_CMD"
REPLACE_DELETE_OLD_MYSQL_DATA="$CFG_REPLACE_DELETE_OLD_MYSQL_DATA"
REPLACE_CLEANUP_CMD="$CFG_REPLACE_CLEANUP_CMD"
if [[ "$MODE" == "replace_slave" ]]; then
  if [[ -z "$TGT_SSH_HOST" ]]; then
    echo "ERROR: Target SSH host is required for replace_slave mode."
    exit 1
  fi
  if [[ -z "$REPLACE_BACKUP_CMD" ]]; then
    REPLACE_BACKUP_CMD="sudo tar -czf /tmp/mysql_slave_backup_\$(date +%Y%m%d_%H%M%S).tgz /var/lib/mysql /etc/mysql /etc/my.cnf 2>/dev/null || true"
  fi
  if [[ -z "$REPLACE_STOP_MYSQL_CMD" ]]; then
    REPLACE_STOP_MYSQL_CMD="sudo systemctl stop mysql || sudo systemctl stop mysqld"
  fi
  if [[ -z "$REPLACE_START_MARIADB_CMD" ]]; then
    REPLACE_START_MARIADB_CMD="sudo systemctl start mariadb || sudo systemctl start mysql"
  fi
  replace_cleanup_check="$(printf "%s" "$REPLACE_CLEANUP_CMD" | tr '[:upper:]' '[:lower:]' | xargs)"
  case "$replace_cleanup_check" in
    y|yes|n|no|true|false) REPLACE_CLEANUP_CMD="" ;;
  esac
  if [[ -z "$REPLACE_TARGET_OS" ]]; then REPLACE_TARGET_OS="ubuntu"; fi
  if [[ -z "$REPLACE_MARIADB_VERSION" ]]; then REPLACE_MARIADB_VERSION="11.8"; fi
  REPLACE_TARGET_OS="$(prompt "Target OS for MariaDB install (ubuntu|debian|rocky|rhel|centos7|sles)" "$REPLACE_TARGET_OS")"
  REPLACE_TARGET_OS="$(printf "%s" "$REPLACE_TARGET_OS" | tr '[:upper:]' '[:lower:]' | xargs)"
  REPLACE_MARIADB_VERSION="$(prompt "MariaDB version to install (for example 11.8)" "$REPLACE_MARIADB_VERSION")"
  REPLACE_MARIADB_VERSION="$(printf "%s" "$REPLACE_MARIADB_VERSION" | xargs)"
  case "$REPLACE_TARGET_OS" in
    ubuntu|debian|rocky|rhel|centos7|sles)
      ;;
    *)
      echo "ERROR: Unsupported target OS '$REPLACE_TARGET_OS'. Use ubuntu|debian|rocky|rhel|centos7|sles."
      exit 1
      ;;
  esac
  replace_customize_cmds="$(prompt "Customize backup/stop/start/uninstall commands? (y/n)" "n")"
  if [[ "$(printf "%s" "$replace_customize_cmds" | tr '[:upper:]' '[:lower:]')" == "y" ]]; then
    REPLACE_BACKUP_CMD="$(prompt "Backup command on target host" "$REPLACE_BACKUP_CMD")"
    REPLACE_STOP_MYSQL_CMD="$(prompt "Stop MySQL command on target host" "$REPLACE_STOP_MYSQL_CMD")"
    REPLACE_UNINSTALL_MYSQL_CMD="$(prompt "Uninstall MySQL command on target host (optional)" "$REPLACE_UNINSTALL_MYSQL_CMD")"
    REPLACE_START_MARIADB_CMD="$(prompt "Start MariaDB command on target host" "$REPLACE_START_MARIADB_CMD")"
  else
    echo "Using default backup/stop/start commands from config."
  fi
  replace_cleanup_answer="$(prompt "Delete old MySQL data after successful replacement? (y/n)" "n")"
  if [[ "$(printf "%s" "$replace_cleanup_answer" | tr '[:upper:]' '[:lower:]')" == "y" ]]; then
    REPLACE_DELETE_OLD_MYSQL_DATA="1"
    REPLACE_CLEANUP_CMD="$(prompt "Cleanup command on target host (required when delete=y)" "$REPLACE_CLEANUP_CMD")"
  else
    REPLACE_DELETE_OLD_MYSQL_DATA="0"
    REPLACE_CLEANUP_CMD=""
  fi
fi

ALLOW_ROOT_USERS="${ALLOW_ROOT_USERS:-0}"
if [[ -z "$SRC_ADMIN_USER" || -z "$SRC_ADMIN_PASS" ]]; then
  echo "ERROR: Source admin user and password are required."
  exit 1
fi
if [[ "$MODE" != "inplace" && ( -z "$TGT_ADMIN_USER" || -z "$TGT_ADMIN_PASS" ) ]]; then
  echo "ERROR: Target admin user and password are required."
  exit 1
fi
if [[ ( "$MODE" == "binlog" || "$MODE" == "replace_slave" ) && ( -z "$REPL_USER" || -z "$REPL_PASS" ) ]]; then
  echo "ERROR: Replication user and password are required for binlog/replace_slave mode."
  exit 1
fi
if [[ "$MODE" == "replace_slave" && -z "$REPLACE_MARIADB_VERSION" ]]; then
  echo "ERROR: MariaDB version is required for replace_slave mode."
  exit 1
fi
if [[ "$MODE" == "replace_slave" && "$REPLACE_DELETE_OLD_MYSQL_DATA" == "1" && -z "$REPLACE_CLEANUP_CMD" ]]; then
  echo "ERROR: Cleanup command is required when delete old MySQL data is enabled."
  exit 1
fi
if [[ "$ALLOW_ROOT_USERS" != "1" ]]; then
  if [[ "$SRC_ADMIN_USER" == "root" || "$TGT_ADMIN_USER" == "root" || "$SRC_USER" == "root" || "$TGT_USER" == "root" ]]; then
    echo "ERROR: root user is not allowed for admin or migration users. Set ALLOW_ROOT_USERS=1 only if explicitly intended."
    exit 1
  fi
fi

yaml_quote() {
  local s="$1"
  s="${s//$'\n'/ }"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf "\"%s\"" "$s"
}

save_config() {
  local cfg="config/migration.yaml"
  local tmp
  tmp="$(mktemp)"
  local backup="${cfg}.bak"
  local include_secrets="${1:-0}"

  local src_pass_save="$SRC_PASS"
  local src_admin_pass_save="$SRC_ADMIN_PASS"
  local tgt_pass_save="$TGT_PASS"
  local tgt_admin_pass_save="$TGT_ADMIN_PASS"
  local app_user_pass_save="$APP_USER_DEFAULT_PASSWORD"
  local repl_pass_save="$REPL_PASS"
  src_admin_pass_save="${src_admin_pass_save#"${src_admin_pass_save%%[![:space:]]*}"}"
  src_admin_pass_save="${src_admin_pass_save%"${src_admin_pass_save##*[![:space:]]}"}"
  tgt_admin_pass_save="${tgt_admin_pass_save#"${tgt_admin_pass_save%%[![:space:]]*}"}"
  tgt_admin_pass_save="${tgt_admin_pass_save%"${tgt_admin_pass_save##*[![:space:]]}"}"
  repl_pass_save="${repl_pass_save#"${repl_pass_save%%[![:space:]]*}"}"
  repl_pass_save="${repl_pass_save%"${repl_pass_save##*[![:space:]]}"}"
  if [[ "$include_secrets" != "1" ]]; then
    src_pass_save=""
    src_admin_pass_save=""
    tgt_pass_save=""
    tgt_admin_pass_save=""
    app_user_pass_save=""
    repl_pass_save=""
  fi

  local mode_val="$MODE"
  local src_db_val=""
  local src_dbs_val=""
  if [[ "$SRC_DBS_INPUT" == *","* ]]; then
    src_dbs_val="$SRC_DBS_INPUT"
  else
    src_db_val="$SRC_DBS_INPUT"
  fi

  awk -v mode_val="$(yaml_quote "$mode_val")" \
      -v src_db="$(yaml_quote "$src_db_val")" \
      -v src_dbs="$(yaml_quote "$src_dbs_val")" \
      -v src_host="$(yaml_quote "$SRC_HOST")" \
      -v src_port="$(yaml_quote "$SRC_PORT")" \
      -v src_user="$(yaml_quote "$SRC_USER")" \
      -v src_pass="$(yaml_quote "$src_pass_save")" \
      -v src_admin_user="$(yaml_quote "$SRC_ADMIN_USER")" \
      -v src_admin_pass="$(yaml_quote "$src_admin_pass_save")" \
      -v tgt_host="$(yaml_quote "$TGT_HOST")" \
      -v tgt_port="$(yaml_quote "$TGT_PORT")" \
      -v tgt_user="$(yaml_quote "$TGT_USER")" \
      -v tgt_pass="$(yaml_quote "$tgt_pass_save")" \
      -v tgt_admin_user="$(yaml_quote "$TGT_ADMIN_USER")" \
      -v tgt_admin_pass="$(yaml_quote "$tgt_admin_pass_save")" \
      -v tgt_ssh_host="$(yaml_quote "$TGT_SSH_HOST")" \
      -v tgt_ssh_user="$(yaml_quote "$TGT_SSH_USER")" \
      -v tgt_ssh_opts="$(yaml_quote "$TGT_SSH_OPTS")" \
      -v mig_app_users="$(yaml_quote "$MIGRATE_APP_USERS")" \
      -v app_user_pass="$(yaml_quote "$app_user_pass_save")" \
      -v repl_user="$(yaml_quote "$REPL_USER")" \
      -v repl_pass="$(yaml_quote "$repl_pass_save")" \
      -v inplace_backup_dir="$(yaml_quote "$INPLACE_BACKUP_DIR")" \
      -v inplace_execute="$(yaml_quote "$INPLACE_EXECUTE")" \
      -v inplace_stop_cmd="$(yaml_quote "$INPLACE_STOP_CMD")" \
      -v inplace_install_cmd="$(yaml_quote "$INPLACE_INSTALL_CMD")" \
      -v inplace_start_cmd="$(yaml_quote "$INPLACE_START_CMD")" \
      -v inplace_upgrade_cmd="$(yaml_quote "$INPLACE_UPGRADE_CMD")" \
      -v replace_backup_cmd="$(yaml_quote "$REPLACE_BACKUP_CMD")" \
      -v replace_stop_mysql_cmd="$(yaml_quote "$REPLACE_STOP_MYSQL_CMD")" \
      -v replace_uninstall_mysql_cmd="$(yaml_quote "$REPLACE_UNINSTALL_MYSQL_CMD")" \
      -v replace_target_os="$(yaml_quote "$REPLACE_TARGET_OS")" \
      -v replace_mariadb_version="$(yaml_quote "$REPLACE_MARIADB_VERSION")" \
      -v replace_start_mariadb_cmd="$(yaml_quote "$REPLACE_START_MARIADB_CMD")" \
      -v replace_delete_old_mysql_data="$(yaml_quote "$REPLACE_DELETE_OLD_MYSQL_DATA")" \
      -v replace_cleanup_cmd="$(yaml_quote "$REPLACE_CLEANUP_CMD")" \
      '
BEGIN { in_env=0 }
{
  if ($0 ~ /^mode:[[:space:]]*/) { print "mode: " mode_val; next }
  if ($0 ~ /^env:[[:space:]]*$/) { in_env=1; print; next }
  if (in_env && $0 ~ /^[^ ]/) { in_env=0 }
  if (in_env) {
    if ($0 ~ /^  SRC_DB:/) { print "  SRC_DB: " src_db; next }
    if ($0 ~ /^  SRC_DBS:/) { print "  SRC_DBS: " src_dbs; next }
    if ($0 ~ /^  SRC_HOST:/) { print "  SRC_HOST: " src_host; next }
    if ($0 ~ /^  SRC_PORT:/) { print "  SRC_PORT: " src_port; next }
    if ($0 ~ /^  SRC_USER:/) { print "  SRC_USER: " src_user; next }
    if ($0 ~ /^  SRC_PASS:/) { print "  SRC_PASS: " src_pass; next }
    if ($0 ~ /^  SRC_ADMIN_USER:/) { print "  SRC_ADMIN_USER: " src_admin_user; next }
    if ($0 ~ /^  SRC_ADMIN_PASS:/) { print "  SRC_ADMIN_PASS: " src_admin_pass; next }
    if ($0 ~ /^  TGT_HOST:/) { print "  TGT_HOST: " tgt_host; next }
    if ($0 ~ /^  TGT_PORT:/) { print "  TGT_PORT: " tgt_port; next }
    if ($0 ~ /^  TGT_USER:/) { print "  TGT_USER: " tgt_user; next }
    if ($0 ~ /^  TGT_PASS:/) { print "  TGT_PASS: " tgt_pass; next }
    if ($0 ~ /^  TGT_ADMIN_USER:/) { print "  TGT_ADMIN_USER: " tgt_admin_user; next }
    if ($0 ~ /^  TGT_ADMIN_PASS:/) { print "  TGT_ADMIN_PASS: " tgt_admin_pass; next }
    if ($0 ~ /^  TGT_SSH_HOST:/) { print "  TGT_SSH_HOST: " tgt_ssh_host; next }
    if ($0 ~ /^  TGT_SSH_USER:/) { print "  TGT_SSH_USER: " tgt_ssh_user; next }
    if ($0 ~ /^  TGT_SSH_OPTS:/) { print "  TGT_SSH_OPTS: " tgt_ssh_opts; next }
    if ($0 ~ /^  MIGRATE_APP_USERS:/) { print "  MIGRATE_APP_USERS: " mig_app_users; next }
    if ($0 ~ /^  APP_USER_DEFAULT_PASSWORD:/) { print "  APP_USER_DEFAULT_PASSWORD: " app_user_pass; next }
    if ($0 ~ /^  REPL_USER:/) { print "  REPL_USER: " repl_user; next }
    if ($0 ~ /^  REPL_PASS:/) { print "  REPL_PASS: " repl_pass; next }
    if ($0 ~ /^  INPLACE_BACKUP_DIR:/) { print "  INPLACE_BACKUP_DIR: " inplace_backup_dir; next }
    if ($0 ~ /^  INPLACE_EXECUTE:/) { print "  INPLACE_EXECUTE: " inplace_execute; next }
    if ($0 ~ /^  INPLACE_STOP_CMD:/) { print "  INPLACE_STOP_CMD: " inplace_stop_cmd; next }
    if ($0 ~ /^  INPLACE_INSTALL_CMD:/) { print "  INPLACE_INSTALL_CMD: " inplace_install_cmd; next }
    if ($0 ~ /^  INPLACE_START_CMD:/) { print "  INPLACE_START_CMD: " inplace_start_cmd; next }
    if ($0 ~ /^  INPLACE_UPGRADE_CMD:/) { print "  INPLACE_UPGRADE_CMD: " inplace_upgrade_cmd; next }
    if ($0 ~ /^  REPLACE_BACKUP_CMD:/) { print "  REPLACE_BACKUP_CMD: " replace_backup_cmd; next }
    if ($0 ~ /^  REPLACE_STOP_MYSQL_CMD:/) { print "  REPLACE_STOP_MYSQL_CMD: " replace_stop_mysql_cmd; next }
    if ($0 ~ /^  REPLACE_UNINSTALL_MYSQL_CMD:/) { print "  REPLACE_UNINSTALL_MYSQL_CMD: " replace_uninstall_mysql_cmd; next }
    if ($0 ~ /^  REPLACE_TARGET_OS:/) { print "  REPLACE_TARGET_OS: " replace_target_os; next }
    if ($0 ~ /^  REPLACE_INSTALL_MARIADB_CMD:/) { next }
    if ($0 ~ /^  REPLACE_MARIADB_VERSION:/) { print "  REPLACE_MARIADB_VERSION: " replace_mariadb_version; next }
    if ($0 ~ /^  REPLACE_START_MARIADB_CMD:/) { print "  REPLACE_START_MARIADB_CMD: " replace_start_mariadb_cmd; next }
    if ($0 ~ /^  REPLACE_DELETE_OLD_MYSQL_DATA:/) { print "  REPLACE_DELETE_OLD_MYSQL_DATA: " replace_delete_old_mysql_data; next }
    if ($0 ~ /^  REPLACE_CLEANUP_CMD:/) { print "  REPLACE_CLEANUP_CMD: " replace_cleanup_cmd; next }
  }
  print
}
' "$cfg" > "$tmp"

  if [[ -f "$cfg" ]]; then
    cp "$cfg" "$backup"
    echo "==> Backup saved: $backup"
  fi
  mv "$tmp" "$cfg"
  echo "==> Saved inputs to $cfg"
}

export SRC_HOST SRC_PORT SRC_USER SRC_PASS SRC_ADMIN_USER SRC_ADMIN_PASS
export TGT_HOST TGT_PORT TGT_USER TGT_PASS TGT_ADMIN_USER TGT_ADMIN_PASS
export MIGRATE_APP_USERS APP_USER_DEFAULT_PASSWORD
if [[ -n "${REPL_USER:-}" ]]; then export REPL_USER; fi
if [[ -n "${REPL_PASS:-}" ]]; then export REPL_PASS; fi
if [[ -n "${INPLACE_BACKUP_DIR:-}" ]]; then export INPLACE_BACKUP_DIR; fi
if [[ -n "${INPLACE_EXECUTE:-}" ]]; then export INPLACE_EXECUTE; fi
if [[ -n "${INPLACE_STOP_CMD:-}" ]]; then export INPLACE_STOP_CMD; fi
if [[ -n "${INPLACE_INSTALL_CMD:-}" ]]; then export INPLACE_INSTALL_CMD; fi
if [[ -n "${INPLACE_START_CMD:-}" ]]; then export INPLACE_START_CMD; fi
if [[ -n "${INPLACE_UPGRADE_CMD:-}" ]]; then export INPLACE_UPGRADE_CMD; fi
if [[ -n "${REPLACE_BACKUP_CMD:-}" ]]; then export REPLACE_BACKUP_CMD; fi
if [[ -n "${REPLACE_STOP_MYSQL_CMD:-}" ]]; then export REPLACE_STOP_MYSQL_CMD; fi
if [[ -n "${REPLACE_UNINSTALL_MYSQL_CMD:-}" ]]; then export REPLACE_UNINSTALL_MYSQL_CMD; fi
if [[ -n "${REPLACE_TARGET_OS:-}" ]]; then export REPLACE_TARGET_OS; fi
if [[ -n "${REPLACE_MARIADB_VERSION:-}" ]]; then export REPLACE_MARIADB_VERSION; fi
if [[ -n "${REPLACE_START_MARIADB_CMD:-}" ]]; then export REPLACE_START_MARIADB_CMD; fi
if [[ -n "${REPLACE_DELETE_OLD_MYSQL_DATA:-}" ]]; then export REPLACE_DELETE_OLD_MYSQL_DATA; fi
if [[ -n "${REPLACE_CLEANUP_CMD:-}" ]]; then export REPLACE_CLEANUP_CMD; fi

if [[ -n "$TGT_SSH_HOST" ]]; then export TGT_SSH_HOST; fi
if [[ -n "$TGT_SSH_USER" ]]; then export TGT_SSH_USER; fi

if [[ "$MODE" != "inplace" && "$SRC_DBS_INPUT" == *","* ]]; then
  export SRC_DBS="$SRC_DBS_INPUT"
elif [[ "$MODE" != "inplace" ]]; then
  export SRC_DB="$SRC_DBS_INPUT"
fi

confirm_save="$(prompt "Save inputs to config/migration.yaml? (y/n)" "n")"
if [[ "$(printf "%s" "$confirm_save" | tr '[:upper:]' '[:lower:]')" == "y" ]]; then
  save_with_passwords="$(prompt "Include passwords/secrets in saved config? (y/n)" "n")"
  if [[ "$(printf "%s" "$save_with_passwords" | tr '[:upper:]' '[:lower:]')" == "y" ]]; then
    save_config 1
  else
    save_config 0
    echo "==> Saved config with passwords redacted."
  fi
else
  echo "==> Skipping config save."
fi

TS="$(date +%Y%m%d_%H%M%S)"
ASSESS_DIR="artifacts/assess_${TS}"
PLAN_DIR="artifacts/plan_${TS}"
RUN_DIR_FILE=".migration_last_run"
RUN_SIG_FILE=".migration_last_signature"

RUN_DIR=""
if [[ -f "$RUN_DIR_FILE" ]]; then
  RUN_DIR="$(cat "$RUN_DIR_FILE" | tr -d '\n')"
fi

CURRENT_SIG="$(run_signature)"
LAST_SIG=""
if [[ -f "$RUN_SIG_FILE" ]]; then
  LAST_SIG="$(cat "$RUN_SIG_FILE")"
fi

if [[ ( "$MODE" == "binlog" || "$MODE" == "replace_slave" ) && -n "$RUN_DIR" && -d "$RUN_DIR" && -f "$RUN_DIR/state.json" && "${FORCE_NEW_RUN:-0}" != "1" ]]; then
  echo "==> Resuming: $MODE (out: $RUN_DIR)"
  python3 -m orchestrator.migrationctl resume --config config/migration.yaml --mode "$MODE" --out "$RUN_DIR"
  STATUS=$?
elif [[ -n "$RUN_DIR" && -d "$RUN_DIR" && -f "$RUN_DIR/state.json" && -n "$LAST_SIG" && "$CURRENT_SIG" == "$LAST_SIG" ]]; then
  echo "==> Resuming: $MODE (out: $RUN_DIR)"
  python3 -m orchestrator.migrationctl resume --config config/migration.yaml --mode "$MODE" --out "$RUN_DIR"
  STATUS=$?
else
  if [[ -n "$RUN_DIR" && -d "$RUN_DIR" && -f "$RUN_DIR/state.json" ]]; then
    echo "==> Previous run found, but inputs changed. Starting a new run directory."
  fi
  # Drop stale resume pointers before a fresh assess/plan/run attempt.
  rm -f "$RUN_DIR_FILE" "$RUN_SIG_FILE"
  if [[ -f "config/source.yaml" ]]; then
    echo "==> Assessing (out: $ASSESS_DIR)"
    python3 -m orchestrator.migrationctl assess --config config/source.yaml --out "$ASSESS_DIR"
  elif [[ -f "config/migration.yaml" ]]; then
    echo "==> Assessing (out: $ASSESS_DIR)"
    python3 -m orchestrator.migrationctl assess --config config/migration.yaml --out "$ASSESS_DIR"
  else
    echo "==> Skipping assess (config/source.yaml and config/migration.yaml not found)"
  fi

  echo "==> Planning: $MODE (out: $PLAN_DIR)"
  python3 -m orchestrator.migrationctl plan --config config/migration.yaml --mode "$MODE" --out "$PLAN_DIR"

  RUN_DIR="artifacts/run_${MODE}_${TS}"
  echo "$RUN_DIR" > "$RUN_DIR_FILE"
  printf "%s" "$CURRENT_SIG" > "$RUN_SIG_FILE"
  echo "==> Running: $MODE (out: $RUN_DIR)"
  python3 -m orchestrator.migrationctl run --config config/migration.yaml --mode "$MODE" --out "$RUN_DIR"
  STATUS=$?
fi

if [[ $STATUS -eq 0 ]]; then
  rm -f "$RUN_DIR_FILE"
  rm -f "$RUN_SIG_FILE"
fi
exit $STATUS
